# ──────────────────────────────────────────────
# IOKNBO Finance Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Supabase ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Clerk (Auth) ──────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# ── OpenAI (Whisper + GPT-4o-mini) ───────────
OPENAI_API_KEY=sk-xxx

# ── Mindee (Receipt OCR) ──────────────────────
MINDEE_API_KEY=your-mindee-key

# ── Currency Exchange ─────────────────────────
EXCHANGE_RATE_API_KEY=your-key
EXCHANGE_RATE_BASE_URL=https://v6.exchangerate-api.com/v6

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ioknbo

# ── Redis (Upstash) ───────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Backend ───────────────────────────────────
BACKEND_PORT=4000
JWT_SECRET=change-me-to-a-random-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Google Drive Backup ───────────────────────
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# ── OneDrive Backup ───────────────────────────
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret

# ── PostHog Analytics ─────────────────────────
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://app.posthog.com

# ── Mobile (Expo) ─────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
EXPO_PUBLIC_BACKEND_URL=http://localhost:4000
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxx
